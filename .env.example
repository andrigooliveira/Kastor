# ────────────────────────────────────────────────────────────────
# Kastor — Template de variáveis de ambiente
#
# Copie pra .env (que NÃO vai pro git) e preencha. No Portainer, cole o
# conteúdo na aba "Environment variables" da Stack ao invés de criar .env
# no servidor.
# ────────────────────────────────────────────────────────────────

# Porta exposta no host. Default 8080 pra evitar conflito com Chatwoot
# (que costuma usar 3000). Ajuste pra qualquer porta livre na sua VPS.
HOST_PORT=8080

# ── Banco de dados (PostgreSQL) — OBRIGATÓRIO ────────────────────
# Formato: postgres://usuario:senha@host:porta/nome_do_banco
# Managed providers (Neon, Supabase, RDS, Railway, Render) geralmente
# exigem SSL — adicione ?sslmode=require ao final da URL.
# Ex.: postgres://kastor:s3nh4@db.exemplo.com:5432/kastor?sslmode=require
DATABASE_URL=

# URL pública (sem barra no final). Usada nos emails de reset de senha
# pra montar o link de volta. Ex.: https://kastor.seudominio.com.br
PUBLIC_URL=

# Segredo de criptografia das sessões/tokens em disco.
# Gere uma vez:  openssl rand -hex 32
# Se deixar vazio, o app gera automaticamente em data/secret.bin —
# funciona, mas se você trocar o volume, todas as sessões expiram.
FLUXO_SECRET=

# Quantos dias uma sessão dura antes de expirar (default 30).
KASTOR_SESSION_DAYS=30

# ── Google Calendar (integração one-way, read-only) ──────────────
# 1) https://console.cloud.google.com → cria projeto
# 2) APIs & Services → Library → ativa "Google Calendar API"
# 3) OAuth consent screen → External (ou Internal se Google Workspace)
#    Scopes: adicionar "https://www.googleapis.com/auth/calendar.readonly"
#            e "https://www.googleapis.com/auth/userinfo.email"
# 4) Credenciais → OAuth Client ID → tipo "Web application"
# 5) Authorized redirect URI: use exatamente o valor de GOOGLE_REDIRECT_URI abaixo
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ── SMTP (opcional — sem isso, "esqueci senha" não envia email) ──
# Funciona com Gmail (porta 587, secure=false), Sendgrid, Mailgun, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=Kastor <noreply@seudominio.com.br>
